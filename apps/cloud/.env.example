# Mindwtr Cloud example environment.
# Copy to .env for local development and replace placeholders before use.

# Network binding
HOST=0.0.0.0
PORT=8787
# NODE_ENV=production

# Authentication
# Use long random bearer tokens. Comma-separate multiple tokens.
MINDWTR_CLOUD_AUTH_TOKENS=replace-with-a-long-random-token
# MINDWTR_CLOUD_AUTH_TOKENS_FILE=/run/secrets/mindwtr_cloud_tokens
# Deprecated legacy single-token aliases; prefer MINDWTR_CLOUD_AUTH_TOKENS.
# MINDWTR_CLOUD_TOKEN=
# MINDWTR_CLOUD_TOKEN_FILE=
# Development/testing only.
# MINDWTR_CLOUD_ALLOW_ANY_TOKEN=false
# MINDWTR_CLOUD_ANY_TOKEN_MAX_NAMESPACES=32

# Browser origin and storage
MINDWTR_CLOUD_CORS_ORIGIN=http://localhost:5173
MINDWTR_CLOUD_DATA_DIR=./data

# Reverse proxy handling for auth-failure rate limiting
MINDWTR_CLOUD_TRUST_PROXY_HEADERS=false
# MINDWTR_CLOUD_TRUSTED_PROXY_IPS=127.0.0.1,::1

# Request limits
MINDWTR_CLOUD_MAX_BODY_BYTES=2000000
MINDWTR_CLOUD_MAX_ATTACHMENT_BYTES=50000000
MINDWTR_CLOUD_REQUEST_TIMEOUT_MS=30000
MINDWTR_CLOUD_MAX_TASK_TITLE_LENGTH=500
MINDWTR_CLOUD_MAX_TASK_QUICK_ADD_LENGTH=2000
MINDWTR_CLOUD_MAX_ITEMS_PER_COLLECTION=50000

# Pagination and list shaping
MINDWTR_CLOUD_LIST_DEFAULT_LIMIT=200
MINDWTR_CLOUD_LIST_MAX_LIMIT=1000

# Rate limiting
MINDWTR_CLOUD_RATE_WINDOW_MS=60000
MINDWTR_CLOUD_RATE_MAX=120
MINDWTR_CLOUD_ATTACHMENT_RATE_MAX=120
MINDWTR_CLOUD_RATE_CLEANUP_MS=60000
MINDWTR_CLOUD_RATE_MAX_KEYS=10000
MINDWTR_CLOUD_AUTH_FAILURE_RATE_MAX=30
